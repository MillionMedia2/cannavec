# Cannavec.ai — Environment Variables
# Copy to .env.local and fill in values

# Pinecone
PINECONE_API_KEY=pcsk_xxxxx
PINECONE_INDEX=plantz1
PINECONE_HOST=plantz1-xxxxxxx.svc.aped-xxxx-xxxx.pinecone.io

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxx
STRIPE_SECRET_KEY=sk_live_xxxxx

# App
NEXT_PUBLIC_APP_URL=https://cannavec.ai

# Email (SMTP — for contact form)
# Gmail: host=smtp.gmail.com, port=587, secure=false, user=you@gmail.com, pass=your-app-password
# Cannavec hosting: check your hosting panel for SMTP details
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=you@example.com
SMTP_PASS=your-app-password
